########################################
# Frontend Environment Variables
########################################

# APIのベースURL（必須）
# Docker環境では nginx 経由の相対パスを使う（CORS回避）
# VITE_API_URL=http://localhost:8000/api
VITE_API_URL=/api

# Vite dev server のプロキシ先（Docker Nginx のホスト側ポート）
# APP_PORT に合わせて設定する
VITE_API_PROXY_TARGET=http://localhost:8000

# APIタイムアウト（ミリ秒）
# 未設定時は 30000ms（30秒）
VITE_API_TIMEOUT=30000

# 実行環境
# development | production | test
VITE_NODE_ENV=development

# デバッグフラグ
# true / false
VITE_DEBUG=true
