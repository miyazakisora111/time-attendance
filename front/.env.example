########################################
# Frontend Environment Variables
########################################

# APIのベースURL（必須）
# 例: http://localhost:8000/api
VITE_API_URL=http://localhost:8000/api

# APIタイムアウト（ミリ秒）
# 未設定時は 30000ms（30秒）
VITE_API_TIMEOUT=30000

# 実行環境
# development | production | test
VITE_NODE_ENV=development

# デバッグフラグ
# true / false
VITE_DEBUG=true
