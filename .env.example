# ===========================================================
# Docker Compose infrastructure variables
# Copy to .env and adjust as needed:  cp .env.example .env
# ===========================================================

COMPOSE_PROJECT_NAME=time-attendance

# ── Build targets ──────────────────────────────────────────
APP_BUILD_TARGET=dev
FRONT_BUILD_TARGET=dev

# ── Backend runtime ───────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost

# ── Published ports ───────────────────────────────────────
APP_PORT=8000
DB_PORT=5432
REDIS_PORT=6379

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_DB=time_attendance
POSTGRES_USER=time_attendance
POSTGRES_PASSWORD=change_me

# ── Frontend build arg ───────────────────────────────────
VITE_API_BASE_URL=/api
