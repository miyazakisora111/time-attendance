# Compose-only infrastructure variables
COMPOSE_PROJECT_NAME=time-attendance

# Build targets
APP_BUILD_TARGET=dev
WEB_BUILD_TARGET=prod

# Backend runtime override injected by compose
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# Published ports
APP_PORT=8000
FRONT_PORT=5173
WEB_PORT=80
DB_PORT=5432
REDIS_PORT=6379

# PostgreSQL initialization
POSTGRES_DB=time_attendance
POSTGRES_USER=time_attendance
POSTGRES_PASSWORD=change_me

# Frontend build arg (compose-level)
VITE_API_BASE_URL=/api

# Vite docker-dev settings
VITE_DEV_PROXY_TARGET=http://web
VITE_HMR_HOST=localhost
VITE_HMR_CLIENT_PORT=5173
